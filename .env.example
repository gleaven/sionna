# ───────────────────────────────────────────────────────────────────
# Host port mappings.
#   APP_PORT     — FastAPI server (UI + REST + WebSocket).
#   JUPYTER_PORT — JupyterLab on /sionna/notebooks (no token, no password).
# ───────────────────────────────────────────────────────────────────
APP_PORT=8080
JUPYTER_PORT=8888

# ───────────────────────────────────────────────────────────────────
# Optional HTTPS reverse proxy (--profile proxy).
# ───────────────────────────────────────────────────────────────────
DEMO_HOSTNAME=localhost
HTTP_PORT=8081
HTTPS_PORT=8443
